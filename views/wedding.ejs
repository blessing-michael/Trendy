<!-- ================= HERO ================= -->

<section class="wedding-hero">

    <video
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/images/wed1.png">

        <source src="/images/wed-vd2.mp4" type="video/mp4">

    </video>

    <div class="hero-overlay">

        <h1>Luxury Turkish Bridal Collection</h1>

        <p>Elegant gowns crafted for your unforgettable day.</p>

        <a href="#collection" class="hero-btn">
            Shop Collection
        </a>

    </div>

</section>



<!-- ================= COLLECTION ================= -->

<section class="trending-page" id="collection">

    <h2>Wedding Collection</h2>

    <div class="container">
        
  <!-- <div class="page-header">
    <h1>🔥 Trending Products</h1>
  </div> -->

  <div class="products-grid">

<% products.forEach(product => { %>

  <a href="/product/<%= product._id %>" class="product-link">

    <div class="product-card">

      <% if(product.type === "video"){ %>

        <video autoplay muted loop playsinline>
          <source src="<%= product.video %>" type="video/mp4">
        </video>

      <% } else { %>

        <img src="<%= product.image %>" alt="<%= product.name %>">

      <% } %>

      <div class="product-info">

        <h3><%= product.name %></h3>

        <div class="price-row">

          <p>$<%= product.price.toLocaleString() %></p>

          <!-- ADD TO CART -->
         <button
  class="cart-btn"
  onclick="event.preventDefault(); addToCart('<%= product._id %>')"
>
  <i class="fa-solid fa-cart-arrow-down"></i>
</button>

        </div>

      </div>

    </div>

  </a>

<% }) %>
  </div>
  </div>


</section>




