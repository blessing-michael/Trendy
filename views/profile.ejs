<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Profile</title>
<link rel="stylesheet" href="/css/feed                    .css">
</head>

<body>

<div class="profile-page">

  <!-- TOP PROFILE CARD -->
  <div class="profile-card">

    <div class="avatar">
      <%= user.username.charAt(0).toUpperCase() %>
    </div>

    <div class="profile-info">
      <h1><%= user.username %></h1>
      <p><%= user.email %></p>

      <div class="stats">
        <div>
          <strong><%= posts.length %></strong>
          <span>Requests</span>
        </div>

        <div>
          <strong>4</strong>
          <span>Target Group</span>
        </div>

        <div>
          <strong>Active</strong>
          <span>Status</span>
        </div>
      </div>

      <div class="profile-actions">
        <a href="/chat" class="btn-dark">Community Feed</a>
        <a href="/logout" class="btn-light">Logout</a>
      </div>
    </div>

  </div>

  <!-- POSTS SECTION -->
  <div class="section-title">
    <h2>My Style Requests</h2>
    <p>Everything you've posted for group buying</p>
  </div>

  <% if(posts.length > 0){ %>

    <div class="post-grid">

      <% posts.forEach(post => { %>

      <div class="post-card">

        <% if(post.image){ %>
          <img src="<%= post.image %>" alt="Post Image">
        <% } else { %>
          <div class="no-image">No Image</div>
        <% } %>

        <div class="post-body">

          <p class="caption"><%= post.text %></p>

          <%
          const total = post.interested.length;
          const groupSize = 4;
          const remaining = total % groupSize;
          const spotsLeft = remaining === 0 ? 0 : groupSize - remaining;
          %>

          <div class="status-box">
            <span>👥 <strong><%= total %></strong> joined</span>

            <% if(spotsLeft === 0 && total > 0){ %>
              <span class="ready">✅ Ready</span>
            <% } else { %>
              <span class="pending">🟢 <%= spotsLeft %> needed</span>
            <% } %>
          </div>

        </div>

      </div>

      <% }) %>

    </div>

  <% } else { %>

    <div class="empty-box">
      <h3>No Requests Yet</h3>
      <p>You haven’t posted any style requests.</p>
      <a href="/chat" class="btn-dark">Post Now</a>
    </div>

  <% } %>

</div>

</body>
</html>