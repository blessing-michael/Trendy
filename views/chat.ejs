<!-- CREATE POST -->
<!-- <form action="/chat/create" method="POST">
  <input name="image" placeholder="upload image">
  <textarea name="text" placeholder="What do you want to buy?" required></textarea>
  <button type="submit">Post</button>
</form> -->
<form action="/chat/create" method="POST" enctype="multipart/form-data">

  <input
    type="file"
    name="image"
    accept="image/*"
    capture="environment"
  >

  <textarea
    name="text"
    placeholder="What do you want to buy?"
    required
  ></textarea>

  <button type="submit">Post</button>

</form>

<hr>

<!-- POSTS -->
<% posts.forEach(post => { %>

<div class="post-card">

  <!-- HEADER -->
  <div class="post-header">
    <%= post.creator.username %>
  </div>

  <!-- IMAGE -->
  <% if (post.image) { %>
    <div class="post-image">
      <img src="<%= post.image %>">
    </div>
  <% } %>

  <!-- CONTENT -->
  <div class="post-content">

    <p class="post-text"><%= post.text %></p>

    <%
    const total = post.interested.length;
    const groupSize = 4;
    const remaining = total % groupSize;
    const spotsLeft = remaining === 0 ? 0 : groupSize - remaining;
    %>

    <div class="group-info">
      👥 <strong><%= total %></strong> interested
      <br>

      <% if (spotsLeft === 0 && total > 0) { %>
        <span style="color:green;">✅ Group ready</span>
      <% } else { %>
        🟢 <%= spotsLeft %> more needed
      <% } %>
    </div>

    <!-- JOIN -->
    <form action="/chat/join/<%= post._id %>" method="POST">
      <select name="size" required>
        <option value="">Size</option>
        <option>10</option>
        <option>12</option>
        <option>14</option>
        <option>16</option>
      </select>

      <input name="location" placeholder="City" required>

      <button class="join-btn">Join Group</button>
    </form>

  </div>

  <!-- COMMENTS -->
  <div class="post-content">
    <% post.comments.forEach(c => { %>
      <div class="comment">
        <strong><%= c.user.username %></strong> <%= c.text %>
      </div>
    <% }) %>
  </div>

  <!-- ADD COMMENT -->
<form class="comment-form" action="/chat/comment/<%= post._id %>" method="POST">

  <input
    type="text"
    name="text"
    placeholder="Add a comment..."
    required
    enterkeyhint="send"
    autocomplete="off"
  >

  <button type="submit">Post</button>

</form>

</div>

<% }) %>
