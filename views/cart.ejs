<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cart</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family: Arial, sans-serif;
    background:#f5f5f5;
    color:#111;
}

/* PAGE */
.container{
    width:95%;
    max-width:1300px;
    margin:auto;
    padding:40px 0;
}

.page-title{
    font-size:32px;
    font-weight:700;
    margin-bottom:30px;
}

/* MAIN LAYOUT */
.cart-layout{
    display:grid;
    grid-template-columns: 2fr 1fr;
    gap:25px;
}

@media(max-width:900px){

    .cart-layout{
        grid-template-columns:1fr;
    }

}

/* LEFT SIDE */
.cart-left{
    display:flex;
    flex-direction:column;
    gap:20px;
}

/* CART CARD */
.cart-card{
    background:#fff;
    border-radius:18px;
    padding:20px;
    display:flex;
    gap:20px;
    box-shadow:0 5px 20px rgba(0,0,0,0.06);
    align-items:flex-start;
}

@media(max-width:700px){

    .cart-card{
        flex-direction:column;
    }

}

/* IMAGE */
.cart-image{
    width:170px;
    height:200px;
    border-radius:14px;
    object-fit:cover;
    background:#eee;
}

/* INFO */
.cart-info{
    flex:1;
}

.product-name{
    font-size:22px;
    font-weight:700;
    margin-bottom:10px;
}

.product-desc{
    color:#666;
    line-height:1.6;
    margin-bottom:15px;
}

/* TAGS */
.tag-row{
    display:flex;
    gap:10px;
    flex-wrap:wrap;
    margin-bottom:15px;
}

.tag{
    background:#f2f2f2;
    padding:7px 12px;
    border-radius:50px;
    font-size:13px;
    font-weight:600;
}

.group-tag{
    background:#ffe9e9;
    color:#d40000;
}

/* PRICE */
.price-row{
    display:flex;
    align-items:center;
    gap:15px;
    margin-bottom:15px;
    flex-wrap:wrap;
}

.single-price{
    font-size:18px;
    font-weight:bold;
}

.group-price{
    color:#d40000;
    font-weight:700;
}

/* QUANTITY */
.qty-wrapper{
    display:flex;
    align-items:center;
    gap:12px;
    margin-bottom:15px;
}

.qty-box{
    display:flex;
    align-items:center;
    gap:10px;
    background:#f3f3f3;
    border-radius:50px;
    padding:5px;
}

.qty-box button{
    width:35px;
    height:35px;
    border:none;
    border-radius:50%;
    cursor:pointer;
    font-size:18px;
    font-weight:bold;
}

.btn-dec{
    background:#222;
    color:#fff;
}

.btn-inc{
    background:#1ea54c;
    color:#fff;
}

/* SUBTOTAL */
.subtotal{
    font-size:18px;
    font-weight:700;
    margin-bottom:15px;
}

/* REMOVE */
.remove-btn{
    background:#ffeded;
    color:#d40000;
    border:none;
    padding:10px 18px;
    border-radius:10px;
    cursor:pointer;
    font-weight:600;
}

/* RIGHT SIDE */
.summary-box{
    background:#fff;
    border-radius:20px;
    padding:25px;
    height:fit-content;
    position:sticky;
    top:20px;
    box-shadow:0 5px 20px rgba(0,0,0,0.06);
}

.summary-title{
    font-size:24px;
    font-weight:700;
    margin-bottom:25px;
}

.summary-row{
    display:flex;
    justify-content:space-between;
    margin-bottom:18px;
    color:#555;
}

.total-row{
    display:flex;
    justify-content:space-between;
    font-size:22px;
    font-weight:700;
    margin:25px 0;
}

/* INFO BOX */
.info-box{
    background:#faf5e9;
    border:1px solid #f0deb1;
    padding:15px;
    border-radius:12px;
    font-size:14px;
    line-height:1.7;
    margin-bottom:20px;
}

/* BUTTONS */
.checkout-btn{
    width:100%;
    padding:16px;
    border:none;
    border-radius:14px;
    background:#111;
    color:#fff;
    font-size:16px;
    font-weight:700;
    cursor:pointer;
    margin-bottom:12px;
}

.continue-btn{
    width:100%;
    padding:14px;
    border:none;
    border-radius:14px;
    background:#f3f3f3;
    font-weight:600;
    cursor:pointer;
}

/* EMPTY */
.empty-box{
    background:#fff;
    padding:60px 20px;
    border-radius:20px;
    text-align:center;
}

</style>

</head>

<body>

<div class="container">

<h1 class="page-title">
    Shopping Cart
</h1>

<% if(cart.length === 0){ %>

<div class="empty-box">

    <h2>Your cart is empty</h2>

</div>

<% } else { %>

<div class="cart-layout">

    <!-- LEFT -->
    <div class="cart-left">

        <% cart.forEach(item => { %>

        <div class="cart-card">

            <!-- IMAGE -->
            <img
                src="<%= item.productId.image || item.productId.images[0] %>"
                class="cart-image"
            >

            <!-- INFO -->
            <div class="cart-info">

                <h2 class="product-name">
                    <%= item.productId.name %>
                </h2>

                <p class="product-desc">
                    <%= item.productId.description || "Premium fashion item for modern buyers." %>
                </p>

                <!-- TAGS -->
                <div class="tag-row">

    <% if(item.size){ %>
        <div class="tag">
            Size: <%= item.size %>
        </div>
    <% } %>

    <% if(item.color){ %>
        <div class="tag">
            Color: <%= item.color %>
        </div>
    <% } %>

    <% if(item.isGroupBuy){ %>
        <div class="tag group-tag">🔥 Group Buy Deal</div>
    <% } %>

    <div class="tag">Fast Shipping</div>
    <div class="tag">Verified Product</div>

</div>

                <!-- PRICE -->
                <div class="price-row">

                    <div class="single-price">
                        ₦<%= item.productId.price %>
                    </div>

                    <% if(item.isGroupBuy){ %>

                    <div class="group-price">
                        Group Price Active
                    </div>

                    <% } %>

                </div>

                <!-- QUANTITY -->
                <div class="qty-wrapper">

                    <span>Quantity</span>

                    <div class="qty-box">

                        <form action="/cart/decrease" method="POST">

                            <input
                                type="hidden"
                                name="productId"
                                value="<%= item.productId._id %>"
                            >

                            <button class="btn-dec">
                                -
                            </button>

                        </form>

                        <span>
                            <%= item.quantity %>
                        </span>

                        <form action="/cart/increase" method="POST">

                            <input
                                type="hidden"
                                name="productId"
                                value="<%= item.productId._id %>"
                            >

                            <button class="btn-inc">
                                +
                            </button>

                        </form>

                    </div>

                </div>

                <!-- SUBTOTAL -->
                <div class="subtotal">

                    Subtotal:
                    ₦<%= item.productId.price * item.quantity %>

                </div>

                <!-- REMOVE -->
                <form action="/cart/remove" method="POST">

                    <input
                        type="hidden"
                        name="productId"
                        value="<%= item.productId._id %>"
                    >

                    <button class="remove-btn">

                        Remove Item

                    </button>

                </form>

            </div>

        </div>

        <% }) %>

    </div>

    <!-- RIGHT -->
    <div class="summary-box">

        <h2 class="summary-title">
            Order Summary
        </h2>

        <div class="summary-row">
            <span>Items</span>
            <span><%= cart.length %></span>
        </div>

        <div class="summary-row">
            <span>Delivery</span>
            <span>Calculated at checkout</span>
        </div>

        <div class="summary-row">
            <span>Group Buy Savings</span>
            <span>Applied</span>
        </div>

        <div class="total-row">
            <span>Total</span>
            <span>₦<%= total %></span>
        </div>

        <!-- INFO -->
        <div class="info-box">

            🔥 Group buy orders may receive lower prices
            when matched with other buyers.

            <br><br>

            Orders are manually reviewed before shipping.

        </div>

        <!-- CHECKOUT -->
        <a href="/checkout">

            <button class="checkout-btn">

                Proceed To Checkout

            </button>

        </a>

        <a href="/">

            <button class="continue-btn">

                Continue Shopping

            </button>

        </a>

    </div>

</div>

<% } %>

</div>

</body>
</html>