<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h2>Your Cart</h2>

    <% if (cart.length===0) { %>
        <p>Your cart is empty.</p>
        <% } else { %>
            <ul>
                <% cart.forEach(item=> { %>
                    <li>
                        <strong>
                            <%= item.productId.name %>
                        </strong> -
                        ₦<%= item.productId.price %> × <%= item.quantity %>
                    </li>
                    <% }) %>
            </ul>
            <% } %>

</body>

</html>