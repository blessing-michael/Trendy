<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Orders</title>

  <style>
    body {
      font-family: Arial;
      background: #f6f6f6;
      margin: 0;
      padding: 20px;
    }

    .container {
      max-width: 900px;
      margin: auto;
    }

    .order {
      background: white;
      padding: 20px;
      margin-bottom: 20px;
      border-radius: 10px;
    }

    .items {
      margin-top: 10px;
      border-top: 1px solid #eee;
      padding-top: 10px;
    }

    .item {
      display: flex;
      justify-content: space-between;
      margin-bottom: 8px;
    }

    .status {
      padding: 5px 10px;
      background: #ddd;
      display: inline-block;
      border-radius: 5px;
      font-size: 12px;
    }

    .total {
      font-weight: bold;
      margin-top: 10px;
    }

    h2 {
      margin-bottom: 20px;
    }
  </style>
</head>

<body>

<div class="container">

  <h2>My Orders</h2>

  <% if (orders.length === 0) { %>
    <p>You have no orders yet.</p>
  <% } %>

  <% orders.forEach(order => { %>

    <div class="order">

      <div>
        <strong>Order ID:</strong> <%= order._id %>
      </div>

      <div>
        <span class="status"><%= order.status %></span>
      </div>

      <div class="items">

        <% order.items.forEach(item => { %>
          <div class="item">
            <span><%= item.productId.name %> × <%= item.quantity %></span>
            <span>₦<%= item.productId.price * item.quantity %></span>
          </div>
        <% }) %>

      </div>

      <div class="total">
        Total: ₦<%= order.total %>
      </div>

      <div style="font-size:12px; margin-top:10px;">
        <%= new Date(order.createdAt).toDateString() %>
      </div>

    </div>

  <% }) %>

</div>

</body>
</html> 